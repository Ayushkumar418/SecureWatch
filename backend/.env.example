# ── SIEM Backend Configuration ─────────────────────────────
# Copy this to .env and fill in your values.
# Never commit .env to Git!

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=siem_db
DB_USER=siem_user
DB_PASSWORD=siem_pass

# Flask API
PORT=5000
FLASK_ENV=production

# Dashboard URL (used in email alert links)
DASHBOARD_URL=http://localhost:3000

# Mode: set to "true" for demo/testing with simulated logs
SIEM_DEMO_MODE=false

# ── Google Gemini AI (Primary — FREE tier) ───────────────────────────
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# ── Anthropic Claude AI (Fallback) ──────────────────────────────────
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Threat Intelligence (Optional) ─────────────────────────────────
# VirusTotal (free: 4 req/min): https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AbuseIPDB (free: 1000 req/day): https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# ── Email Alerts via Gmail ───────────────────────────────────────────
# Step 1: Enable 2FA on Gmail
# Step 2: https://myaccount.google.com/apppasswords → create app password
# Step 3: Paste the 16-char password as SMTP_PASS below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
ALERT_EMAIL=your_gmail@gmail.com
