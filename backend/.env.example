# ── SIEM Backend Configuration ─────────────────────────────
# Copy this to .env and fill in your values.
# Never commit .env to Git!

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=siem_db
DB_USER=siem_user
DB_PASS=siem_pass

# Flask API
PORT=5000
FLASK_ENV=production

# ── Anthropic Claude API (Phase 3) ──────────────────────────────────────
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Email Alerts via Gmail (Phase 3) ────────────────────────────────────
# Step 1: Enable 2FA on Gmail
# Step 2: https://myaccount.google.com/apppasswords → create app password
# Step 3: Paste the 16-char password as SMTP_PASS below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
ALERT_EMAIL=your_gmail@gmail.com
